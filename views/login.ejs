<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shortify | Login & Register</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/register.css">
    <link rel="stylesheet" href="/login.css">
    <script src="/login-register.js" defer></script>
</head>
<body>
    <div id="authRoot" data-is-login="<%= !!isLogin %>"></div>

    <template id="loginTemplate">
        <div class="login-container">
            <div class="logoBar">
                <img src="" alt="logo">
                <p>Name</p>
            </div>
            <h1 class="mainHeading">WELCOME BACK</h1>
            <p class="subHeading">Pick up where you left off. Shorten, share, and track your links securely.</p>
            <form action="/auth/login" method="post">
                <label for="emailInput">Email</label>
                <input type="email" name="email" id="emailInput" placeholder="Enter your email" autocomplete="email" required>
                <label for="passwordInput">Password</label>
                <span class="passwordSpan">
                    <input type="password" name="password" id="passwordInput" placeholder="Enter your password" autocomplete="current-password" required minlength="8">
                    <svg id="visibility" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="m644-428-58-58q9-47-27-88t-93-32l-58-58q17-8 34.5-12t37.5-4q75 0 127.5 52.5T660-500q0 20-4 37.5T644-428Zm128 126-58-56q38-29 67.5-63.5T832-500q-50-101-143.5-160.5T480-720q-29 0-57 4t-55 12l-62-62q41-17 84-25.5t90-8.5q151 0 269 83.5T920-500q-23 59-60.5 109.5T772-302Zm20 246L624-222q-35 11-70.5 16.5T480-200q-151 0-269-83.5T40-500q21-53 53-98.5t73-81.5L56-792l56-56 736 736-56 56ZM222-624q-29 26-53 57t-41 67q50 101 143.5 160.5T480-280q20 0 39-2.5t39-5.5l-36-38q-11 3-21 4.5t-21 1.5q-75 0-127.5-52.5T300-500q0-11 1.5-21t4.5-21l-84-82Zm319 93Zm-151 75Z"/></svg>
                </span>
                <span>
                    <div class="checkbox-wrapper-46">
                    <input type="checkbox" id="cbx-46" class="inp-cbx" name="remember"/>
                    <label for="cbx-46" class="cbx"><span>
                        <svg viewBox="0 0 12 10" height="10px" width="12px">
                            <polyline points="1.5 6 4.5 9 10.5 1"></polyline></svg></span><span>Remember me</span>
                    </label>
                    </div>
                    <a href="#">Forgot Password</a>
                </span>
                <button type="submit">Log in</button>
            </form>
            <p>or</p>
            <p style="font-size: small; font-weight: 200;">Don't have an Account? <span style="color:white ;font-weight:600; cursor:pointer" id="switchAuth">Sign up</span></p>
        </div>
    </template>

    <template id="registerTemplate">
        <div class="register-container">
            <div class="logoBar">
                <img src="" alt="logo">
                <p>Name</p>
            </div>

            <h1 class="mainHeading">CREATE ACCOUNT</h1>
            <p class="subHeading">Start creating branded short links with smart tracking and built-in QR codes.</p>

            <form action="/auth/signup" method="POST">
                <label for="emailInput">Email</label>
                <input type="email" name="email" id="emailInput" placeholder="Enter your email" autocomplete="email" required>

                <label for="passwordInput">Password</label>
                <span class="passwordSpan">
                    <input type="password" name="password" id="passwordInput" placeholder="Create a password" autocomplete="new-password" required minlength="8">
                    <svg id="visibility" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="m644-428-58-58q9-47-27-88t-93-32l-58-58q17-8 34.5-12t37.5-4q75 0 127.5 52.5T660-500q0 20-4 37.5T644-428Zm128 126-58-56q38-29 67.5-63.5T832-500q-50-101-143.5-160.5T480-720q-29 0-57 4t-55 12l-62-62q41-17 84-25.5t90-8.5q151 0 269 83.5T920-500q-23 59-60.5 109.5T772-302Zm20 246L624-222q-35 11-70.5 16.5T480-200q-151 0-269-83.5T40-500q21-53 53-98.5t73-81.5L56-792l56-56 736 736-56 56ZM222-624q-29 26-53 57t-41 67q50 101 143.5 160.5T480-280q20 0 39-2.5t39-5.5l-36-38q-11 3-21 4.5t-21 1.5q-75 0-127.5-52.5T300-500q0-11 1.5-21t4.5-21l-84-82Zm319 93Zm-151 75Z"/></svg>
                </span>
                <button type="submit">Sign up</button>
            </form>

            <p class="switchAuth">Already account? <a style="cursor: pointer;" id="switchAuth">Sign in</a></p>
        </div>
    </template>
</body>
</html>