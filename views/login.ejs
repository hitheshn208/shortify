<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shortify | Login & Register</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/register.css">
    <link rel="stylesheet" href="/login.css">
    <script src="/login-register.js" defer></script>
</head>
<body>
    <div id="authRoot" data-is-login="<%= !!isLogin %>"></div>

    <template id="loginTemplate">
        <div class="auth-wrapper">
            <div class="auth-card">
                <div class="auth-header">
                    <h1 class="mainHeading">Welcome Back</h1>
                    <p class="subHeading">Sign in to your account to continue</p>
                </div>

                <div class="auth-message" id="authMessage" aria-live="polite"></div>

                <form class="auth-form" data-endpoint="/auth/login" data-success-redirect="/user/dashboard">
                    <div class="form-group">
                        <label for="emailInput">Email Address</label>
                        <input type="email" name="email" id="emailInput" placeholder="you@example.com" autocomplete="email" required>
                    </div>

                    <div class="form-group">
                        <div class="password-label-wrapper">
                            <label for="passwordInput">Password</label>
                            <a href="#" class="forgot-password">Forgot?</a>
                        </div>
                        <div class="password-input-wrapper">
                            <input type="password" name="password" id="passwordInput" placeholder="Enter your password" autocomplete="current-password" required minlength="8">
                            <button type="button" class="password-toggle" id="visibility">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="#6b7280"><path d="m644-428-58-58q9-47-27-88t-93-32l-58-58q17-8 34.5-12t37.5-4q75 0 127.5 52.5T660-500q0 20-4 37.5T644-428Zm128 126-58-56q38-29 67.5-63.5T832-500q-50-101-143.5-160.5T480-720q-29 0-57 4t-55 12l-62-62q41-17 84-25.5t90-8.5q151 0 269 83.5T920-500q-23 59-60.5 109.5T772-302Zm20 246L624-222q-35 11-70.5 16.5T480-200q-151 0-269-83.5T40-500q21-53 53-98.5t73-81.5L56-792l56-56 736 736-56 56ZM222-624q-29 26-53 57t-41 67q50 101 143.5 160.5T480-280q20 0 39-2.5t39-5.5l-36-38q-11 3-21 4.5t-21 1.5q-75 0-127.5-52.5T300-500q0-11 1.5-21t4.5-21l-84-82Zm319 93Zm-151 75Z"/></svg>
                            </button>
                        </div>
                    </div>

                    <div class="form-group checkbox-group">
                        <div class="checkbox-wrapper-46">
                            <input type="checkbox" id="cbx-46" class="inp-cbx" name="remember"/>
                            <label for="cbx-46" class="cbx"><span>
                                <svg viewBox="0 0 12 10" height="10px" width="12px">
                                    <polyline points="1.5 6 4.5 9 10.5 1"></polyline>
                                </svg>
                            </span><span>Remember me</span></label>
                        </div>
                    </div>

                    <button type="submit" class="auth-button primary-button">Sign In</button>
                </form>

                <div class="divider">
                    <span>or</span>
                </div>

                <button type="button" class="auth-button google-button" id="googleLoginBtn">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19.6 10.23c0-.82-.1-1.42-.25-2.05H10v3.72h5.5c-.15.96-.74 2.31-2.04 3.22v2.45h3.16c1.89-1.73 2.98-4.3 2.98-7.34z" fill="#4285F4"/>
                        <path d="M13.46 15.13c-.83.63-1.96 1.25-3.46 1.25-2.64 0-4.84-1.74-5.64-4.15H1.07v2.52C2.72 17.75 6.17 20 10 20c2.7 0 4.96-.89 6.62-2.45l-3.16-2.42z" fill="#34A853"/>
                        <path d="M3.99 10c0-.69.12-1.35.32-1.97V5.51H1.07A9.973 9.973 0 000 10c0 1.61.39 3.14 1.07 4.49l3.24-2.52c-.2-.62-.32-1.28-.32-1.97z" fill="#FBBC05"/>
                        <path d="M10 3.88c1.88 0 3.13.98 3.84 1.8l2.85-2.76C14.96 1.33 12.7 0 10 0 6.17 0 2.72 2.25 1.07 5.51l3.24 2.52c.8-2.41 3-4.15 5.69-4.15z" fill="#EA4335"/>
                    </svg>
                    Continue with Google
                </button>

                <p class="auth-footer">Don't have an account? <span id="switchAuth" class="switch-link">Sign up</span></p>
            </div>
        </div>
    </template>

    <template id="otpTemplate">
        <div class="auth-wrapper">
            <div class="auth-card">
                <div class="auth-header">
                    <h1 class="mainHeading">Verify Your Email</h1>
                    <p class="subHeading">We've sent a 6-digit code to your email. Enter it below to continue.</p>
                    <p class="otp-email-display">Code sent to <span id="otpEmailText">your email</span></p>
                </div>

                <div class="auth-message" id="authMessage" aria-live="polite"></div>

                <form class="auth-form otp-form" data-endpoint="/auth/verify-otp">
                    <input type="hidden" name="email" id="otpEmailInput">
                    <div class="form-group">
                        <label>OTP Code</label>
                        <div class="otp-inputs">
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" placeholder="0" required>
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" placeholder="0" required>
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" placeholder="0" required>
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" placeholder="0" required>
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" placeholder="0" required>
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" placeholder="0" required>
                        </div>
                        <input type="hidden" name="otp" id="otpCombined">
                    </div>

                    <button type="submit" class="auth-button primary-button">Verify Code</button>
                </form>

                <div class="divider">
                    <span>or</span>
                </div>

                <p class="auth-footer">Didn't receive the code? <a href="#" id="resendOtp" class="resend-link">Resend</a><span id="resendTimer" class="resend-timer"></span></p>
                <button type="button" id="backToRegister" class="auth-back-link">Change email</button>
            </div>
        </div>
    </template>

    <template id="nameTemplate">
        <div class="auth-wrapper">
            <div class="auth-card">
                <div class="auth-header">
                    <h1 class="mainHeading">Tell us about you</h1>
                    <p class="subHeading">Enter your name to finish setting up your account.</p>
                </div>

                <div class="auth-message" id="authMessage" aria-live="polite"></div>

                <form class="auth-form name-form" data-endpoint="/auth/complete-profile" data-success-redirect="/user/dashboard">
                    <input type="hidden" name="email" id="nameEmailInput">
                    <div class="form-group">
                        <label for="nameInput">Full Name</label>
                        <input type="text" name="name" id="nameInput" placeholder="Your full name" required>
                    </div>

                    <button type="submit" class="auth-button primary-button">Continue to Dashboard</button>
                </form>
            </div>
        </div>
    </template>
    <template id="registerTemplate">
        <div class="auth-wrapper">
            <div class="auth-card">
                <div class="auth-header">
                    <h1 class="mainHeading">Create Account</h1>
                    <p class="subHeading">Start shortening and tracking your links</p>
                </div>

                <div class="auth-message" id="authMessage" aria-live="polite"></div>

                <form class="auth-form" data-endpoint="/auth/signup" data-success-redirect="/user/dashboard">
                    <div class="form-group">
                        <label for="emailInput">Email Address</label>
                        <input type="email" name="email" id="emailInput" placeholder="you@example.com" autocomplete="email" required>
                    </div>

                    <div class="form-group">
                        <label for="passwordInput">Password</label>
                        <div class="password-input-wrapper">
                            <input type="password" name="password" id="passwordInput" placeholder="Create a password (min 8 characters)" autocomplete="new-password" required minlength="8">
                            <button type="button" class="password-toggle" id="visibility">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="#6b7280"><path d="m644-428-58-58q9-47-27-88t-93-32l-58-58q17-8 34.5-12t37.5-4q75 0 127.5 52.5T660-500q0 20-4 37.5T644-428Zm128 126-58-56q38-29 67.5-63.5T832-500q-50-101-143.5-160.5T480-720q-29 0-57 4t-55 12l-62-62q41-17 84-25.5t90-8.5q151 0 269 83.5T920-500q-23 59-60.5 109.5T772-302Zm20 246L624-222q-35 11-70.5 16.5T480-200q-151 0-269-83.5T40-500q21-53 53-98.5t73-81.5L56-792l56-56 736 736-56 56ZM222-624q-29 26-53 57t-41 67q50 101 143.5 160.5T480-280q20 0 39-2.5t39-5.5l-36-38q-11 3-21 4.5t-21 1.5q-75 0-127.5-52.5T300-500q0-11 1.5-21t4.5-21l-84-82Zm319 93Zm-151 75Z"/></svg>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="auth-button primary-button">Create Account</button>
                </form>

                <div class="divider">
                    <span>or</span>
                </div>

                <button type="button" class="auth-button google-button" id="googleSignupBtn">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19.6 10.23c0-.82-.1-1.42-.25-2.05H10v3.72h5.5c-.15.96-.74 2.31-2.04 3.22v2.45h3.16c1.89-1.73 2.98-4.3 2.98-7.34z" fill="#4285F4"/>
                        <path d="M13.46 15.13c-.83.63-1.96 1.25-3.46 1.25-2.64 0-4.84-1.74-5.64-4.15H1.07v2.52C2.72 17.75 6.17 20 10 20c2.7 0 4.96-.89 6.62-2.45l-3.16-2.42z" fill="#34A853"/>
                        <path d="M3.99 10c0-.69.12-1.35.32-1.97V5.51H1.07A9.973 9.973 0 000 10c0 1.61.39 3.14 1.07 4.49l3.24-2.52c-.2-.62-.32-1.28-.32-1.97z" fill="#FBBC05"/>
                        <path d="M10 3.88c1.88 0 3.13.98 3.84 1.8l2.85-2.76C14.96 1.33 12.7 0 10 0 6.17 0 2.72 2.25 1.07 5.51l3.24 2.52c.8-2.41 3-4.15 5.69-4.15z" fill="#EA4335"/>
                    </svg>
                    Sign up with Google
                </button>

                <p class="auth-footer">Already have an account? <span id="switchAuth" class="switch-link">Sign in</span></p>
            </div>
        </div>
    </template>
</body>
</html>