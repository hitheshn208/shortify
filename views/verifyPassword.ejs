<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Protected Link | Shortify</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-blue: #0F63DC;
            --primary-indigo: #0b4fc2;
            --primary-blue-light: #E8F0FF;
            --primary-soft: #f3f8ff;
            --ink-900: #111827;
            --text-gray: #4B5563;
            --text-soft: #667085;
            --border-gray: #E5E7EB;
            --white: #FFFFFF;
            --error-red: #EF4444;
            --font-sans: 'Manrope', 'Segoe UI', sans-serif;
            --font-display: 'Space Grotesk', 'Manrope', sans-serif;
            --transition: all 0.25s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-sans);
            color: var(--text-gray);
            min-height: 100vh;
            background:
                radial-gradient(circle at 10% -10%, rgba(44, 168, 255, 0.18), transparent 36%),
                radial-gradient(circle at 100% 0%, rgba(15, 99, 220, 0.14), transparent 32%),
                var(--white);
            padding: 24px 16px;
        }

        .verify-shell {
            max-width: 640px;
            margin: 0 auto;
            border: 1px solid var(--border-gray);
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.92);
            padding: 24px;
        }

        .verify-title {
            font-family: var(--font-display);
            color: var(--ink-900);
            font-size: 1.9rem;
            line-height: 1.2;
            letter-spacing: -0.02em;
        }

        .verify-subtitle {
            color: var(--text-soft);
            margin-top: 8px;
        }

        .verify-form {
            margin-top: 20px;
            display: grid;
            gap: 10px;
        }

        .verify-form label {
            color: var(--ink-900);
            font-weight: 700;
            font-size: 0.95rem;
        }

        .verify-form input {
            width: 100%;
            border: 1px solid var(--border-gray);
            border-radius: 12px;
            padding: 12px 14px;
            font-size: 1rem;
            color: var(--ink-900);
            outline: none;
            transition: var(--transition);
        }

        .password-input-wrap {
            position: relative;
        }

        .password-input-wrap input {
            padding-right: 48px;
        }

        .password-visibility-btn {
            position: absolute;
            top: 50%;
            right: 8px;
            transform: translateY(-50%);
            width: 34px;
            height: 34px;
            border: none;
            background: transparent;
            border-radius: 8px;
            display: grid;
            place-items: center;
            cursor: pointer;
            padding: 0;
        }

        .password-visibility-btn:hover,
        .password-visibility-btn:focus-visible {
            background: var(--primary-soft);
            outline: none;
        }

        .password-visibility-btn img {
            width: 18px;
            height: 18px;
            opacity: 0.65;
            transition: var(--transition);
        }

        .password-visibility-btn:hover img,
        .password-visibility-btn:focus-visible img {
            opacity: 1;
        }

        .verify-form input:focus {
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 3px rgba(15, 99, 220, 0.12);
        }

        .verify-btn {
            margin-top: 4px;
            border: 2px solid var(--primary-blue);
            background: linear-gradient(135deg, var(--primary-blue), var(--primary-indigo));
            color: var(--white);
            border-radius: 12px;
            padding: 11px 16px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
        }

        .verify-btn:hover {
            transform: translateY(-1px);
        }

        .verify-btn:disabled {
            opacity: 0.75;
            cursor: not-allowed;
            transform: none;
        }

        .verify-message {
            min-height: 22px;
            font-size: 0.93rem;
            margin-top: 2px;
            color: var(--error-red);
            font-weight: 600;
        }

        @media (max-width: 600px) {
            .verify-shell {
                padding: 18px;
                border-radius: 14px;
            }

            .verify-title {
                font-size: 1.55rem;
            }
        }
    </style>
</head>
<body>
    <main class="verify-shell">
        <h1 class="verify-title">The Page is protected</h1>
        <p class="verify-subtitle">Enter the password to continue to the destination website.</p>

        <form id="verifyForm" class="verify-form" action="/<%= Shortcode %>/verify" method="post" novalidate>
            <label for="password">Password</label>
            <div class="password-input-wrap">
                <input id="password" type="password" name="password" placeholder="Enter password" required>
                <button type="button" id="passwordVisibilityBtn" class="password-visibility-btn" aria-label="Show password">
                    <img id="passwordVisibilityIcon" src="/assets/visibility.svg" alt="" aria-hidden="true">
                </button>
            </div>
            <p id="verifyMessage" class="verify-message" aria-live="polite"></p>
            <button id="verifyBtn" type="submit" class="verify-btn">Continue</button>
        </form>
    </main>

    <script>
        const verifyForm = document.getElementById("verifyForm");
        const passwordInput = document.getElementById("password");
        const passwordVisibilityBtn = document.getElementById("passwordVisibilityBtn");
        const passwordVisibilityIcon = document.getElementById("passwordVisibilityIcon");
        const verifyBtn = document.getElementById("verifyBtn");
        const verifyMessage = document.getElementById("verifyMessage");

        function setMessage(message) {
            verifyMessage.textContent = message || "";
        }

        function setPasswordIcon(isVisible) {
            passwordVisibilityIcon.src = isVisible
                ? "/assets/visibility_off_black.svg"
                : "/assets/visibility_black.svg";
            passwordVisibilityBtn.setAttribute("aria-label", isVisible ? "Hide password" : "Show password");
        }

        passwordVisibilityBtn.addEventListener("click", () => {
            const isVisible = passwordInput.type === "text";
            passwordInput.type = isVisible ? "password" : "text";
            setPasswordIcon(!isVisible);
        });

        verifyForm.addEventListener("submit", async (event) => {
            event.preventDefault();

            const password = passwordInput.value.trim();
            if (!password) {
                setMessage("Password is required.");
                return;
            }

            setMessage("");
            verifyBtn.disabled = true;
            verifyBtn.textContent = "Checking...";

            try {
                const response = await fetch(verifyForm.action, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "Accept": "application/json"
                    },
                    body: JSON.stringify({ password })
                });

                const result = await response.json();

                if (response.ok && result.redirectUrl) {
                    verifyBtn.textContent = "Redirecting...";
                    window.location.replace(result.redirectUrl);
                    return;
                }
                verifyBtn.disabled = false;
                verifyBtn.textContent = "Continue";

                setMessage(result.message || "Password verification failed.");
            } catch (error) {
                setMessage("Could not verify password. Please try again.");
            } finally {
                
            }
        });
    </script>
</body>
</html>