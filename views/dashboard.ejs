<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Shortify</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,0,0" rel="stylesheet">
    <link rel="stylesheet" href="/dashboard.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="/dashboard.js" defer></script>
</head>
<body>
    <header class="navbar">
        <div class="container nav-content">
            <a href="/user/dashboard" class="logo" aria-label="Dashboard home">
                <span class="logo-placeholder"><img src="/assets/logo.png" alt="logo"></span>
                <span class="brand-name">Shortify</span>
            </a>

            <div class="nav-actions">
                <button type="button" class="nav-link-btn" id="myLinksNavBtn">My Links</button>

                <div class="profile-menu-wrap">
                    <button type="button" id="profileToggle" class="profile-toggle" aria-expanded="false" aria-controls="profileDropdown">
                        <span class="material-symbols-rounded">account_circle</span>
                    </button>

                    <div id="profileDropdown" class="profile-dropdown" aria-hidden="true">
                        <% /* TODO: render user display name below when available in backend payload */ %>
                        <p class="profile-name"><%= user.name || 'User Name' %></p>
                        <% /* Current backend already provides user.email */ %>
                        <p class="profile-email"><%= user.email %></p>
                        <button class="btn btn-primary profile-logout" id="logout">Logout</button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="dashboard-main">
        <section class="dashboard-section create-link-section">
            <div class="container">
                <div class="section-head">
                    <h1>Create New Link</h1>
                    <p>Shorten and share in seconds with optional protection.</p>
                </div>

                <form id="createLinkForm" class="create-link-form" novalidate>
                    <label for="originalUrl">Long URL</label>
                    <input
                        type="url"
                        id="originalUrl"
                        name="originalUrl"
                        placeholder="https://example.com/your-very-long-link"
                        required
                    >

                    <div class="password-toggle-row">
                        <label class="toggle-label" for="passwordToggle">Password protection</label>
                        <label class="switch">
                            <input type="checkbox" id="passwordToggle" name="passwordToggle">
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div id="passwordFieldWrap" class="password-field-wrap hidden">
                        <label for="linkPassword">Link password</label>
                        <div class="password-input-wrap">
                            <input
                                type="password"
                                id="linkPassword"
                                name="linkPassword"
                                placeholder="Enter password"
                                autocomplete="new-password"
                            >
                            <button
                                type="button"
                                id="passwordVisibilityBtn"
                                class="password-visibility-btn"
                                aria-label="Show password"
                            >
                                <img id="passwordVisibilityIcon" src="/assets/visibility.svg" alt="" aria-hidden="true">
                            </button>
                        </div>
                    </div>

                    <p id="formMessage" class="form-message" aria-live="polite"></p>
                    <button type="submit" id="createLinkBtn" class="btn btn-primary">Create Short Link</button>
                </form>
            </div>
        </section>

        <section class="dashboard-section stats-section">
            <div class="container">
                <div class="section-head">
                    <h2>Stats Overview</h2>
                </div>

                <div class="stats-grid">
                    <article class="stat-card">
                        <span class="material-symbols-rounded stat-icon">link</span>
                        <div>
                            <p class="stat-label">Total Links Created</p>
                            <p id="totalLinksCount" class="stat-value"><%= urls.length %></p>
                        </div>
                    </article>

                    <article class="stat-card">
                        <span class="material-symbols-rounded stat-icon">insights</span>
                        <div>
                            <p class="stat-label">Total Clicks</p>
                            <p id="totalClicksCount" class="stat-value"><%= urls.reduce((sum, item) => sum + (item.visit_count || 0), 0) %></p>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <section class="dashboard-section links-section" id="myLinksSection">
            <div class="container">
                <div class="section-head">
                    <h2>My Links</h2>
                </div>

                <div id="linksContainer" class="links-list">
                    <% if (urls.length) { 
                        urls.sort((a,b)=> (b.is_protected - a.is_protected) || (b.visit_count - a.visit_count))
                        %>
                        <% urls.forEach((url) => { %>
                            <% const isProtected = url.is_protected %>
                            <% /* TODO: if your details route differs, replace data-detail-url generation accordingly */ %>
                            <article
                                class="link-card"
                                tabindex="0"
                                role="button"
                                data-detail-url="<%= `/user/${url.short_code}/details` %>"
                            >
                                <div class="link-main">
                                    <div class="short-link-row">
                                        <a
                                            class="link-title short-link-anchor"
                                            href="/<%= url.short_code %>"
                                            target = "_blank"
                                            rel = "noopener noreferrer"
                                            data-copy-url="http://localhost:3000/<%= url.short_code %>"
                                        >
                                            http://localhost:3000/<%= url.short_code %>
                                        </a>
                                        <button type="button" class="short-link-copy-btn" aria-label="Copy short link">
                                            <span class="material-symbols-rounded">content_copy</span>
                                        </button>
                                    </div>
                                    <p class="link-original"><%= url.original_url %></p>
                                </div>
                                <div class="link-meta">
                                    <span class="lock-badge <%= isProtected ? 'locked' : 'unlocked' %>">
                                        <span class="material-symbols-rounded lock-badge-icon"><%= isProtected ? 'lock' : 'lock_open' %></span>
                                        <span><%= isProtected ? 'Protected' : 'Public' %></span>
                                    </span>
                                    <span class="click-count"><%= url.visit_count || 0 %> Clicks</span>
                                </div>
                            </article>
                        <% }) %>
                    <% } else { %>
                        <div id="emptyState" class="empty-state">
                            <p>No links yet. Create your first short link above.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </section>
    </main>

    <div id="resultModal" class="result-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="resultTitle">
        <div class="modal-panel">
            <button type="button" class="modal-close" id="modalCloseBtn" aria-label="Close modal">×</button>
            <h3 id="resultTitle">Short Link Created</h3>
            <p class="modal-success-msg">Your short URL is ready.</p>

            <div class="modal-link-box">
                <a href="#" id="generatedShortUrl" target="_blank" rel="noopener noreferrer"></a>
                <button type="button" id="copyBtn" class="btn-copy">Copy</button>
            </div>
            <p id="copyFeedback" class="copy-feedback" aria-live="polite"></p>

            <div class="modal-actions">
                <button type="button" id="generateQrBtn" class="btn btn-secondary" disabled>Generate QR Code</button>
                <a id="downloadQrBtn" class="btn btn-primary hidden" href="#" download="short-link-qr.png">Download QR</a>
            </div>

            <div id="qrContainer" class="qr-container hidden"></div>
        </div>
    </div>

    <template id="linkCardTemplate">
        <article class="link-card" tabindex="0" role="button" data-detail-url="">
            <div class="link-main">
                <div class="short-link-row">
                    <a class="link-title short-link-anchor" href="#" data-copy-url="" target = "_blank" rel = "noopener noreferrer"></a>
                    <button type="button" class="short-link-copy-btn" aria-label="Copy short link">
                        <span class="material-symbols-rounded">content_copy</span>
                    </button>
                </div>
                <p class="link-original"></p>
            </div>
            <div class="link-meta">
                <span class="lock-badge"></span>
                <span class="click-count">0 Clicks</span>
            </div>
        </article>
    </template>
</body>
</html>